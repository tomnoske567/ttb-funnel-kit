---
import "../styles/global.css";
import { site } from "../config";

interface Props {
  title?: string;
  description?: string;
}

const { title = site.name, description = site.description } = Astro.props;
const fullTitle = title === site.name ? title : `${title} | ${site.name}`;
---

<!doctype html>
<html
  lang="en"
  data-theme={site.theme}
  data-preset={site.preset}
  data-theme-preset={site.themePreset}
  data-default-theme={site.theme}
  data-default-theme-preset={site.themePreset}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Apply a saved theme/preset/customiser choice before paint to avoid a flash. */}
    <script is:inline>
      (function () {
        try {
          var root = document.documentElement;
          var t = localStorage.getItem("ttb-theme");
          if (t === "light" || t === "dark") root.dataset.theme = t;
          var p = localStorage.getItem("ttb-preset");
          if (p) root.dataset.preset = p;
          var tp = localStorage.getItem("ttb-theme-preset");
          if (tp) root.dataset.themePreset = tp;
          var c = localStorage.getItem("ttb-customizer");
          if (c) {
            var vars = JSON.parse(c);
            for (var k in vars) root.style.setProperty(k, vars[k]);
          }
        } catch (e) {}
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="min-h-[100dvh] bg-surface text-ink">
    <slot />

    <script>
      // Recolour the favicon to match the current brand accent + theme, and
      // keep it in sync as the Customise Theme panel changes colour/theme.
      const brandColor = () => {
        const probe = document.createElement("span");
        probe.style.cssText = "display:none;color:var(--color-brand-500)";
        document.body.appendChild(probe);
        const c = getComputedStyle(probe).color;
        probe.remove();
        return c || "#14a89e";
      };
      const setFavicon = () => {
        const svg =
          '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">' +
          '<rect width="32" height="32" rx="7" fill="' + brandColor() + '"/>' +
          '<path d="M16 22V11M11.5 15.5 16 11 20.5 15.5" fill="none" stroke="#fff" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/>' +
          "</svg>";
        let link = document.querySelector('link[rel="icon"]');
        if (!link) {
          link = document.createElement("link");
          link.setAttribute("rel", "icon");
          document.head.appendChild(link);
        }
        link.setAttribute("type", "image/svg+xml");
        link.setAttribute("href", "data:image/svg+xml," + encodeURIComponent(svg));
      };
      setFavicon();
      new MutationObserver(setFavicon).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["data-theme", "data-theme-preset", "style"],
      });
    </script>
  </body>
</html>
