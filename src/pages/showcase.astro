---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import ThemeCustomizer from "../components/ThemeCustomizer.astro";

// Internal preview page — every hero mode, same content, stacked.
// Not linked in any nav. Delete before shipping a real page if you like.
const heroContent = {
  eyebrow: "Time to Build Funnel Kit",
  headline:
    'Simple, AI-powered landing pages that <span class="text-brand-500">actually convert</span>',
  subheadline:
    "Build a branded, high-converting landing page in under an hour using Claude and a design system that won't let AI make it ugly.",
  bullets: [
    "8 conversion-ready templates",
    "Brand it in one command",
    "Free hosting on Cloudflare",
    "Emails flow into your Kit",
  ],
  ctaLabel: "Get the kit",
  secondaryLabel: "See how it works",
  secondaryHref: "#",
  trustLabel: "Used by 1,000+ creators",
};

const variants = [
  { mode: "split", label: "Split", desc: "Copy left, media right. The default." },
  { mode: "vsl", label: "Centered VSL", desc: "Centered copy with a video player." },
  { mode: "text", label: "Plain text", desc: "Copy only, centered. No media." },
] as const;
---

<Base
  title="Showcase — Hero variations"
  description="Internal preview of the Funnel Kit hero modes."
>
  <header class="border-b border-line bg-surface-2">
    <div class="mx-auto max-w-6xl px-6 py-10">
      <p class="text-sm font-bold uppercase tracking-wide text-brand-600">
        Component showcase
      </p>
      <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-ink md:text-4xl">
        Hero variations
      </h1>
      <p class="mt-3 max-w-2xl text-lg leading-relaxed text-ink-muted">
        Every hero mode, same content — so you can pick the one that fits your
        offer. Set it with the <code
          class="rounded bg-card px-1.5 py-0.5 text-[0.95em] text-ink">mode</code
        > prop on the <code
          class="rounded bg-card px-1.5 py-0.5 text-[0.95em] text-ink">&lt;Hero /&gt;</code
        > component. Open the <strong class="font-semibold text-ink">Customise
        Theme</strong> panel (bottom-right) to recolour, restyle, and flip
        light/dark live.
      </p>
    </div>
  </header>

  {
    variants.map((v) => (
      <article class="border-b border-line">
        <div class="mx-auto max-w-6xl px-6 pt-10">
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
            <span class="rounded-full bg-ink px-3 py-1 font-mono text-xs font-semibold text-surface">
              mode="{v.mode}"
            </span>
            <span class="text-sm font-semibold text-ink">{v.label}</span>
            <span class="text-sm text-ink-muted">— {v.desc}</span>
          </div>
        </div>
        <Hero mode={v.mode} {...heroContent} />
      </article>
    ))
  }

  <footer class="bg-surface">
    <p class="mx-auto max-w-6xl px-6 py-10 text-sm text-ink-muted">
      That's all three hero modes. Want one of these on a real page? Drop in{" "}
      <code class="rounded bg-card px-1.5 py-0.5 text-ink">&lt;Hero mode="…" /&gt;</code>{" "}
      with your own content.
    </p>
  </footer>

  <ThemeCustomizer />
</Base>
