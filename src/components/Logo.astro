---
import { site } from "../config";

interface Props {
  /** Show the brand name next to the mark. */
  showName?: boolean;
}

const { showName = true } = Astro.props;
---

<a href="/" class="flex items-center gap-2" aria-label={site.name}>
  {/*
    Default logo mark: an upward arrow in a brand-coloured box.
    The box uses the brand colour, so it updates automatically when a student
    changes their colour in /brand-setup. Swap this whole <span> for your own
    logo image/SVG whenever you like.
  */}
  <span
    class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-500 text-white"
  >
    <svg
      class="h-[18px] w-[18px]"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M12 19V6" />
      <path d="m6 12 6-6 6 6" />
    </svg>
  </span>

  {showName && (
    <span class="text-base font-bold tracking-tight text-ink">{site.name}</span>
  )}
</a>
