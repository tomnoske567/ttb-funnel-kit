---
import CtaButton from "./CtaButton.astro";

// Shared hero copy block, reused by every Hero mode.
// `align` controls left vs centered. An optional named slot "media" renders
// between the subheadline and the bullets (used by the VSL mode for its video).
interface Props {
  align?: "left" | "center";
  eyebrow?: string;
  headline: string;
  subheadline?: string;
  bullets?: string[];
  ctaLabel: string;
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  trustLabel?: string;
}

const {
  align = "left",
  eyebrow,
  headline,
  subheadline,
  bullets = [],
  ctaLabel,
  ctaHref,
  secondaryLabel,
  secondaryHref,
  trustLabel,
} = Astro.props;

const isCenter = align === "center";
const hasMedia = Astro.slots.has("media");

// Placeholder avatar stack for the trust row (students swap for real ones).
const avatars = [1, 2, 3, 4, 5, 6].map(
  (n) => `https://i.pravatar.cc/64?img=${n * 11}`
);

const headlineColor = "text-ink";
const subColor = "text-ink-muted";
const bulletColor = "text-ink";
const eyebrowLook = "border-ink/15 text-ink";
const trustColor = "text-ink-muted";
const avatarBorder = "border-surface";
---

<div class={isCenter ? "flex flex-col items-center text-center" : ""}>
  {
    eyebrow && (
      <span
        class={`inline-flex items-center gap-2 rounded-full border bg-transparent px-3.5 py-1.5 text-sm font-medium ${eyebrowLook}`}
      >
        <span class="relative flex h-2 w-2" aria-hidden="true">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-500 opacity-75 motion-reduce:animate-none" />
          <span class="relative inline-flex h-2 w-2 rounded-full bg-brand-500" />
        </span>
        {eyebrow}
      </span>
    )
  }

  <h1
    class={`mt-5 text-4xl font-extrabold leading-[1.05] tracking-tight md:text-5xl ${headlineColor}`}
    set:html={headline}
  />

  {
    subheadline && (
      <p
        class={`mt-5 max-w-xl text-lg leading-relaxed ${subColor} ${isCenter ? "mx-auto" : ""}`}
      >
        {subheadline}
      </p>
    )
  }

  {
    hasMedia && (
      <div class={`mt-8 w-full ${isCenter ? "mx-auto max-w-2xl" : ""}`}>
        <slot name="media" />
      </div>
    )
  }

  {
    bullets.length > 0 && (
      <ul
        class={`mt-6 ${isCenter ? "flex flex-wrap justify-center gap-x-5 gap-y-2.5" : "grid gap-3 sm:grid-cols-2"}`}
      >
        {bullets.map((b) => (
          <li
            class={`flex gap-2.5 ${bulletColor} ${isCenter ? "items-center" : "items-start"}`}
          >
            <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-500">
              <svg
                class="h-3 w-3 text-brand-ink"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="m5 13 4 4 10-12" />
              </svg>
            </span>
            <span class="text-sm leading-snug">{b}</span>
          </li>
        ))}
      </ul>
    )
  }

  <div
    class={`mt-8 flex w-full flex-col gap-3 sm:w-auto sm:flex-row sm:items-center ${isCenter ? "sm:justify-center" : ""}`}
  >
    <CtaButton label={ctaLabel} href={ctaHref} class="w-full sm:w-auto" />
    {
      secondaryLabel && (
        <CtaButton
          label={secondaryLabel}
          href={secondaryHref}
          variant="outline"
          class="w-full sm:w-auto"
        />
      )
    }
  </div>

  {
    trustLabel && (
      <div class={`mt-6 flex items-center gap-3 ${isCenter ? "justify-center" : ""}`}>
        <div class="flex -space-x-2">
          {avatars.map((src) => (
            <img
              src={src}
              alt=""
              width="28"
              height="28"
              class={`h-7 w-7 rounded-full border-2 object-cover ${avatarBorder}`}
              loading="lazy"
            />
          ))}
        </div>
        <div class="text-left">
          <div
            class="flex text-sm leading-none tracking-wide text-brand-500"
            aria-hidden="true"
          >
            &#9733;&#9733;&#9733;&#9733;&#9733;
          </div>
          <p class={`mt-1 text-xs font-medium ${trustColor}`}>{trustLabel}</p>
        </div>
      </div>
    )
  }
</div>
