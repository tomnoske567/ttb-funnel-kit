---
// A row of headline stats for quick credibility, right under the hero.
interface Stat {
  value: string; // e.g. "1,000+"
  label: string; // e.g. "students"
}

interface Props {
  stats: Stat[];
  /** Dark band (inverted) vs light. Default dark, like most offer pages. */
  tone?: "dark" | "light";
}

const { stats, tone = "dark" } = Astro.props;
const isDark = tone === "dark";
---

<section class={isDark ? "bg-surface-dark text-ink-dark" : "bg-surface-2 text-ink"}>
  <div class="mx-auto max-w-6xl px-6 py-10">
    <div class="grid grid-cols-2 gap-x-6 gap-y-8 sm:grid-cols-3 lg:grid-cols-5">
      {
        stats.map((s) => (
          <div class="text-center">
            <div class="text-3xl font-extrabold tracking-tight md:text-4xl">
              {s.value}
            </div>
            <div
              class={`mt-1 text-xs font-medium uppercase tracking-wide ${
                isDark ? "text-ink-dark/60" : "text-ink-muted"
              }`}
            >
              {s.label}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
