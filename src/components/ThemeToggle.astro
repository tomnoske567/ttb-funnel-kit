---
// Light/dark toggle. Flips data-theme on <html> and remembers the choice in
// localStorage. Drop it anywhere (we add it to the nav on the demo). For a
// single-theme site, omit it and just set `theme` in config.ts.
---

<button
  type="button"
  data-theme-toggle
  aria-label="Toggle dark mode"
  class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-line text-ink-muted transition-colors hover:bg-surface-2 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2"
>
  {/* Moon: shown in light mode (click -> go dark) */}
  <svg
    data-icon-moon
    class="h-5 w-5"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" />
  </svg>
  {/* Sun: shown in dark mode (click -> go light) */}
  <svg
    data-icon-sun
    class="hidden h-5 w-5"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
  </svg>
</button>

<script>
  const toggles = document.querySelectorAll("[data-theme-toggle]");

  const syncIcons = () => {
    const dark = document.documentElement.dataset.theme === "dark";
    toggles.forEach((btn) => {
      btn.querySelector("[data-icon-sun]")?.classList.toggle("hidden", !dark);
      btn.querySelector("[data-icon-moon]")?.classList.toggle("hidden", dark);
    });
  };

  toggles.forEach((btn) => {
    btn.addEventListener("click", () => {
      const dark = document.documentElement.dataset.theme === "dark";
      const next = dark ? "light" : "dark";
      document.documentElement.dataset.theme = next;
      try {
        localStorage.setItem("ttb-theme", next);
      } catch (e) {}
      syncIcons();
    });
  });

  syncIcons();
</script>
