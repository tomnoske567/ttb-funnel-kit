---
import { site } from "../config";

interface Props {
  label: string;
  href?: string;
  note?: string;
}
const { label, href = site.checkoutUrl, note } = Astro.props;
---

<div
  data-sticky-cta
  class="fixed inset-x-0 bottom-0 z-40 translate-y-full border-t border-line bg-surface/95 backdrop-blur transition-transform duration-300 ease-out lg:hidden"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    {note && <p class="hidden text-sm font-semibold text-ink sm:block">{note}</p>}
    <a
      href={href}
      class="w-full rounded-control bg-brand-500 px-6 py-3 text-center text-base font-semibold text-brand-ink transition hover:bg-brand-600 active:translate-y-px sm:w-auto"
    >
      {label}
    </a>
  </div>
</div>

<script>
  const bar = document.querySelector("[data-sticky-cta]");
  const sentinel = document.querySelector("[data-sticky-sentinel]");
  if (bar && sentinel) {
    const io = new IntersectionObserver(
      ([entry]) => {
        // Show the bar only once the sentinel has scrolled above the viewport
        // (i.e. the user has scrolled past the hero). Hidden on load + in hero.
        const scrolledPast = entry.boundingClientRect.top < 0;
        bar.classList.toggle("translate-y-full", !scrolledPast);
      },
      { threshold: 0 }
    );
    io.observe(sentinel);
  }
</script>
