---
import Logo from "./Logo.astro";
import TextLink from "./TextLink.astro";
import { site } from "../config";

interface Props {
  tagline?: string;
}
const { tagline } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-line bg-surface">
  <div
    class="mx-auto flex max-w-6xl flex-col items-center gap-6 px-6 py-10 sm:flex-row sm:items-center sm:justify-between"
  >
    <div class="flex flex-col items-center gap-3 sm:items-start">
      <Logo />
      {tagline && <p class="text-sm text-ink-muted">{tagline}</p>}
    </div>
    <nav class="flex items-center gap-6 text-sm">
      <TextLink href="/privacy">Privacy</TextLink>
      <TextLink href="/terms">Terms</TextLink>
    </nav>
  </div>
  <div class="border-t border-line">
    <p class="mx-auto max-w-6xl px-6 py-4 text-center text-xs text-ink-muted sm:text-left">
      &copy; {year} {site.name}. All rights reserved.
    </p>
  </div>
</footer>
