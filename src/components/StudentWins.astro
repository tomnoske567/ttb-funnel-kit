---
// Rotating "student wins" card - one result-led win at a time.
// Distinct from the testimonial section: a win leads with the concrete
// OUTCOME (the headline), then the quote, then the person. Auto-rotates;
// pauses on hover/focus; respects prefers-reduced-motion.
interface Win {
  result: string; // the hero line, e.g. "0 -> first opt-in page live in 40 min"
  quote: string;
  name: string;
  meta: string; // handle / role line
  image?: string; // optional photo; falls back to an initial
}
interface Props {
  eyebrow?: string;
  heading: string;
  subheading?: string;
  wins: Win[];
  tone?: "surface" | "surface-2";
}

const {
  eyebrow,
  heading,
  subheading,
  wins,
  tone = "surface-2",
} = Astro.props;

const sectionBg = tone === "surface" ? "bg-surface" : "bg-surface-2";
const initial = (name: string) => name.trim().charAt(0).toUpperCase();
---

<section class={sectionBg}>
  <div class="mx-auto max-w-3xl px-6 py-16 md:py-20">
    <div class="mx-auto max-w-2xl text-center">
      {
        eyebrow && (
          <p class="text-sm font-bold uppercase tracking-wide text-brand-600">
            {eyebrow}
          </p>
        )
      }
      <h2
        class="mt-3 text-3xl font-bold tracking-tight text-ink md:text-4xl"
      >
        {heading}
      </h2>
      {
        subheading && (
          <p class="mx-auto mt-4 max-w-xl text-lg leading-relaxed text-ink-muted">
            {subheading}
          </p>
        )
      }
    </div>

    <div class="relative mt-10" data-wins>
      <!-- Slides stacked in one grid cell so the card sizes to the tallest win -->
      <div class="grid">
        {
          wins.map((w, i) => (
            <article
              class={`col-start-1 row-start-1 rounded-card border border-line bg-card p-7 shadow-sm shadow-black/5 transition-all duration-500 ease-out sm:p-8 ${
                i === 0
                  ? "opacity-100"
                  : "pointer-events-none translate-y-3 scale-[0.98] opacity-0"
              }`}
              data-wins-slide
              data-index={i}
              aria-hidden={i === 0 ? "false" : "true"}
            >
              <p class="text-xs font-semibold uppercase tracking-[0.1em] text-brand-600">
                Student win
              </p>
              <p class="mt-3 font-display text-2xl font-bold leading-tight tracking-tight text-ink md:text-[1.75rem]">
                {w.result}
              </p>
              <blockquote class="mt-4 text-base leading-relaxed text-ink-muted">
                &#8220;{w.quote}&#8221;
              </blockquote>
              <div class="mt-6 flex items-center gap-3 border-t border-line pt-5">
                {w.image ? (
                  <img
                    src={w.image}
                    alt={w.name}
                    width="44"
                    height="44"
                    class="h-11 w-11 shrink-0 rounded-full object-cover"
                    loading="lazy"
                  />
                ) : (
                  <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-chip text-base font-bold text-chip-ink">
                    {initial(w.name)}
                  </span>
                )}
                <div class="min-w-0">
                  <div class="text-sm font-semibold text-ink">{w.name}</div>
                  <div class="text-xs text-ink-muted">{w.meta}</div>
                </div>
              </div>
            </article>
          ))
        }
      </div>

      {
        wins.length > 1 && (
          <div class="mt-7 flex items-center justify-center gap-4">
            <button
              type="button"
              data-wins-prev
              aria-label="Previous win"
              class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-ink-muted transition-colors hover:bg-surface-2 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m15 18-6-6 6-6" />
              </svg>
            </button>

            <div class="flex items-center gap-2" data-wins-dots>
              {wins.map((_, i) => (
                <button
                  type="button"
                  data-wins-dot
                  data-index={i}
                  aria-label={`Go to win ${i + 1}`}
                  class="h-2 w-2 rounded-full bg-line transition-all duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2"
                />
              ))}
            </div>

            <button
              type="button"
              data-wins-next
              aria-label="Next win"
              class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-ink-muted transition-colors hover:bg-surface-2 hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m9 6 6 6-6 6" />
              </svg>
            </button>
          </div>
        )
      }
    </div>
  </div>
</section>

<script>
  // Toggled at runtime; listed here so Tailwind keeps them in the build:
  // bg-brand-500 w-5 bg-line w-2 opacity-100 opacity-0 translate-y-3 scale-[0.98] pointer-events-none
  document.querySelectorAll<HTMLElement>("[data-wins]").forEach((root) => {
    const slides = Array.from(
      root.querySelectorAll<HTMLElement>("[data-wins-slide]")
    );
    const dots = Array.from(
      root.querySelectorAll<HTMLElement>("[data-wins-dot]")
    );
    if (slides.length < 2) return;

    let current = 0;
    let timer: number | undefined;
    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    const show = (n: number) => {
      current = (n + slides.length) % slides.length;
      slides.forEach((slide, i) => {
        const active = i === current;
        slide.classList.toggle("opacity-100", active);
        slide.classList.toggle("opacity-0", !active);
        slide.classList.toggle("translate-y-3", !active);
        slide.classList.toggle("scale-[0.98]", !active);
        slide.classList.toggle("pointer-events-none", !active);
        slide.setAttribute("aria-hidden", active ? "false" : "true");
      });
      dots.forEach((dot, i) => {
        const active = i === current;
        dot.classList.toggle("bg-brand-500", active);
        dot.classList.toggle("w-5", active);
        dot.classList.toggle("bg-line", !active);
        dot.classList.toggle("w-2", !active);
      });
    };

    const next = () => show(current + 1);

    const stop = () => {
      if (timer) window.clearInterval(timer);
      timer = undefined;
    };
    const start = () => {
      if (reduce) return;
      stop();
      timer = window.setInterval(next, 5500);
    };

    root
      .querySelector("[data-wins-next]")
      ?.addEventListener("click", () => {
        show(current + 1);
        start();
      });
    root
      .querySelector("[data-wins-prev]")
      ?.addEventListener("click", () => {
        show(current - 1);
        start();
      });
    dots.forEach((dot) =>
      dot.addEventListener("click", () => {
        show(Number(dot.dataset.index));
        start();
      })
    );

    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);
    root.addEventListener("focusin", stop);
    root.addEventListener("focusout", start);

    show(0);
    start();
  });
</script>
