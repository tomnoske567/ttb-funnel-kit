---
import { site } from "../config";
import PricingToggle from "./PricingToggle.tsx";

interface LineItem {
  label: string;
  value: string;
}
interface PaymentOption {
  label: string; // "Pay in full" / "Split"
  price: string; // "$297"
  suffix?: string; // " x2"
  note?: string; // "one-time"
  href?: string;
  featured?: boolean; // "best value" highlight
}
interface Plan {
  amount: number; // 49
  suffix: string; // "/mo"
  href?: string;
}
interface Membership {
  monthly: Plan;
  annual: Plan;
  annualNote?: string;
  ctaLabel?: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  deliverables: LineItem[];
  bonuses?: LineItem[];
  totalValue: string;
  priceLabel?: string;
  discountNote?: string;
  // One-time: pass `options`. Recurring: pass `membership` (monthly/annual toggle).
  options?: PaymentOption[];
  membership?: Membership;
  badges?: string[];
}

const {
  eyebrow = "Your checkout",
  title,
  deliverables,
  bonuses = [],
  totalValue,
  priceLabel = "Your price today",
  discountNote,
  options = [],
  membership,
  badges = [],
} = Astro.props;

const featured = options.find((o) => o.featured) ?? options[0];
const monthlyHref = membership?.monthly.href ?? site.checkoutUrl;
const annualHref = membership?.annual.href ?? site.checkoutUrl;
---

<section class="mx-auto max-w-3xl px-6 py-16 md:py-20" id="checkout">
  <p class="text-xs font-bold uppercase tracking-wide text-brand-600">{eyebrow}</p>
  <h2
    class="mt-3 text-3xl font-bold tracking-tight text-ink md:text-4xl"
    set:html={title}
  />

  <div class="mt-8 rounded-card bg-surface-dark p-6 text-ink-dark md:p-8">
    <!-- What you get -->
    <p class="text-xs font-semibold uppercase tracking-wide text-brand-400">
      What you get
    </p>
    <ul class="mt-3 divide-y divide-white/10">
      {
        deliverables.map((d) => (
          <li class="flex items-center justify-between gap-4 py-2.5 text-sm">
            <span>{d.label}</span>
            <span class="shrink-0 font-medium text-ink-dark/60">{d.value}</span>
          </li>
        ))
      }
    </ul>

    {
      bonuses.length > 0 && (
        <>
          <p class="mt-6 text-xs font-semibold uppercase tracking-wide text-brand-400">
            Bonuses
          </p>
          <ul class="mt-3 divide-y divide-white/10">
            {bonuses.map((b) => (
              <li class="flex items-center justify-between gap-4 py-2.5 text-sm">
                <span>{b.label}</span>
                <span class="shrink-0 font-medium text-brand-400">{b.value}</span>
              </li>
            ))}
          </ul>
        </>
      )
    }

    <!-- Totals -->
    <div class="mt-6 border-t border-white/15 pt-5">
      <div class="flex items-center justify-between text-sm">
        <span class="font-semibold uppercase tracking-wide">Total value</span>
        <span class="font-bold">{totalValue}</span>
      </div>

      {
        membership ? (
          <div class="mt-6">
            <PricingToggle
              client:load
              monthly={{ ...membership.monthly, href: monthlyHref }}
              annual={{ ...membership.annual, href: annualHref }}
              annualNote={membership.annualNote}
              ctaLabel={membership.ctaLabel}
            />
          </div>
        ) : (
          <>
            <div class="mt-3 flex items-end justify-between">
              <div>
                <span class="text-sm font-semibold uppercase tracking-wide">{priceLabel}</span>
                {discountNote && <p class="mt-0.5 text-xs text-ink-dark/60">{discountNote}</p>}
              </div>
              <span class="text-4xl font-extrabold leading-none text-brand-400">
                {featured.price}
                {featured.suffix && <span class="text-lg font-bold">{featured.suffix}</span>}
              </span>
            </div>
            <div class="mt-6 space-y-3">
              {options.map((o, i) => (
                <>
                  {i > 0 && (
                    <div class="text-center text-xs font-semibold uppercase tracking-wide text-ink-dark/40">
                      or
                    </div>
                  )}
                  <a
                    href={o.href ?? site.checkoutUrl}
                    class={`block rounded-control px-6 py-4 text-center transition active:translate-y-px ${
                      o.featured
                        ? "bg-brand-500 text-brand-ink hover:bg-brand-600"
                        : "border border-white/25 text-ink-dark hover:border-white/50"
                    }`}
                  >
                    <span class="block text-base font-bold">
                      {o.label} - {o.price}
                      {o.suffix ?? ""}
                    </span>
                    {o.note && <span class="mt-0.5 block text-xs opacity-70">{o.note}</span>}
                  </a>
                </>
              ))}
            </div>
          </>
        )
      }
    </div>

    {
      badges.length > 0 && (
        <div class="mt-5 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-[11px] font-medium uppercase tracking-wide text-ink-dark/50">
          {badges.map((b) => (
            <span>{b}</span>
          ))}
        </div>
      )
    }
  </div>
</section>
